# Copy this file to .env and fill in real values. Never commit the real .env file.

# Long random string used to sign sessions & CSRF tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database connection string.
# Local development (default if unset): sqlite:///floods.db
# Production (e.g. Postgres on Heroku/Render): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///floods.db

# Set to "false" in production
FLASK_DEBUG=false

# Set to "true" once deployed live behind HTTPS (keep "false" for local http://127.0.0.1)
SESSION_COOKIE_SECURE=false

# Google OAuth ("Continue with Google").
# Get these from https://console.cloud.google.com/ -> APIs & Services -> Credentials.
# Leave blank to disable the Google sign-in button entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
